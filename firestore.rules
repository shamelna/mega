rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Profiles collection rules
    match /profiles/{userId} {
      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can write their own profile, admins can write any profile
      allow write, create: if request.auth != null && 
        (request.auth.uid == userId ||
         request.auth.uid == 'hVwyXJI729XhWVluq77v7Jt5KDn2' ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'));
      
      // Admins can read any profile
      allow read: if request.auth != null && 
        (request.auth.uid == 'hVwyXJI729XhWVluq77v7Jt5KDn2' ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'));
    }
    
    // Assessments collection rules
    match /assessments/{assessmentId} {
      // Users can read their own assessments
      allow read: if request.auth != null && request.auth.uid == resource.data.user_id;
      
      // Users can create their own assessments, admins can create any
      allow create: if request.auth != null && 
        (request.auth.uid == request.resource.data.user_id ||
         request.auth.uid == 'hVwyXJI729XhWVluq77v7Jt5KDn2' ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'));
      
      // Users and admins can update assessments
      allow write: if request.auth != null && 
        (request.auth.uid == resource.data.user_id ||
         request.auth.uid == 'hVwyXJI729XhWVluq77v7Jt5KDn2' ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'));
      
      // Admins can read any assessment
      allow read: if request.auth != null && 
        (request.auth.uid == 'hVwyXJI729XhWVluq77v7Jt5KDn2' ||
         (exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin'));
    }
    
    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
